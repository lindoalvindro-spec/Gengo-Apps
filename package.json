{
  "name": "gengo",
  "version": "1.0.0",
  "description": "Live game translator — capture, OCR, and translate game text in real-time",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.gengo.app",
    "productName": "Gengo",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": ".",
        "to": "traineddata",
        "filter": ["*.traineddata"]
      }
    ],
    "win": {
      "target": "portable"
    }
  },
  "keywords": [
    "translator",
    "game",
    "ocr",
    "visual-novel",
    "electron"
  ],
  "author": "Gengo",
  "license": "MIT",
  "dependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1"
  }
}
